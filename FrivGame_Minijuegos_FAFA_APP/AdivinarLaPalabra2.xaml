<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrivGame_Minijuegos_FAFA_APP.AdivinarLaPalabra2"
             Title="AdivinarLaPalabra2">


    <Grid RowDefinitions="Auto, *, Auto, Auto" Padding="5, 5, 5, 10" RowSpacing="5">

        <ScrollView Grid.Row="1" VerticalOptions="Center" VerticalScrollBarVisibility="Never">
            <VerticalStackLayout Spacing="10" VerticalOptions="Center">
                <Grid x:Name="GridTablero" HorizontalOptions="Center" 
                  ColumnSpacing="4" RowSpacing="4" />
                <Label x:Name="LabelMensaje" HorizontalOptions="Center" 
                   FontSize="16" TextColor="White" HeightRequest="25" />
            </VerticalStackLayout>
        </ScrollView>

        <Button Grid.Row="2" 
            x:Name="ButtonReiniciar"
            Clicked="RecargarJuego" 
            Text="Volver A jugar" 
            HorizontalOptions="Center" 
            Margin="0,5" 
            IsVisible="False"/>

        <VerticalStackLayout Grid.Row="3" 
                         x:Name="KeyboardLayout" 
                         Spacing="4" 
                         HorizontalOptions="Fill" 
                         Margin="0,0,0,5" />

    </Grid>


</ContentPage>